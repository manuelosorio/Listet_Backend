{
  "name": "listet_backend",
  "version": "1.0.0",
  "description": "Backend api for Listet",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "concurrently -k -n 'TypeScript,Node' -c 'yellow.bold,cyan.bold' 'npm run watch-ts' 'nodemon ./dist/server.js' -i true --default-input-target 1",
    "dev:verbose": "nodemon --watch src/ --exec 'npm run build && npm start' --verbose -e ts",
    "watch-ts": "tsc -w",
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "yarn node --experimental-vm-modules $(yarn bin jest)",
    "test:unit": "NODE_ENV=test jest tests/unit",
    "test:e2e": "NODE_ENV=test jest tests/e2e",
    "test:watch": "NODE_ENV=test jest --watch",
    "typecheck": "tsc --project tsconfig.test.json --noEmit",
    "snyk:protect": "snyk-protect",
    "snyk:test": "snyk test",
    "prepare": "npm run snyk:protect"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manuelosorio/Listet_Backend.git"
  },
  "keywords": [
    "Todo",
    "list",
    "angular",
    "express",
    "backend",
    "fullstack"
  ],
  "author": "Manuel Osorio",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/manuelosorio/Listet_Backend.git/issues"
  },
  "homepage": "https://github.com/manuelosorio/Listet_Backend.git#readme",
  "dependencies": {
    "@snyk/protect": "^1.1302.1",
    "@socket.io/cluster-adapter": "^0.3.0",
    "bcrypt": "^6.0.0",
    "chalk": "^4.1.2",
    "concurrently": "^6.5.1",
    "cors": "^2.8.5",
    "dotenv": "^9.0.2",
    "email-templates": "^13.0.1",
    "express": "^4.19.2",
    "express-flash": "0.0.2",
    "express-mysql-session": "^3.0.0",
    "express-session": "^1.18.1",
    "helmet": "^4.6.0",
    "morgan": "^1.10.1",
    "mysql": "^2.18.1",
    "nodemailer": "^7.0.11",
    "pug": "^3.0.2",
    "socket.io": "^4.6.2"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@swc/core": "^1.15.18",
    "@swc/jest": "^0.2.39",
    "@types/bcrypt": "^6.0.0",
    "@types/chalk": "^2.2.0",
    "@types/cors": "^2.8.13",
    "@types/email-templates": "^8.0.4",
    "@types/express": "^4.17.17",
    "@types/express-flash": "0.0.2",
    "@types/express-mysql-session": "^2.1.3",
    "@types/express-session": "^1.17.6",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.4",
    "@types/mysql": "^2.15.21",
    "@types/node": "^14.18.36",
    "@types/nodemailer": "^6.4.7",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^8.6.0",
    "eslint-plugin-prettier": "^3.4.1",
    "jest": "^30.3.0",
    "nodemon": "^3.0.0",
    "prettier": "^2.5.1",
    "supertest": "^7.2.2",
    "typescript": "^4.9.5"
  },
  "imports": {
    "#api/*": {
      "types": "./src/api/*.ts",
      "default": "./dist/api/*.js"
    },
    "#controllers/*": {
      "types": "./src/controllers/*.ts",
      "default": "./dist/controllers/*.js"
    },
    "#database/*": {
      "types": "./src/database/*.ts",
      "default": "./dist/database/*.js"
    },
    "#environments/*": {
      "types": "./src/environments/*.ts",
      "default": "./dist/environments/*.js"
    },
    "#helper/*": {
      "types": "./src/helper/*.ts",
      "default": "./dist/helper/*.js"
    },
    "#middleware/*": {
      "types": "./src/middleware/*.ts",
      "default": "./dist/middleware/*.js"
    },
    "#models/*": {
      "types": "./src/models/*.ts",
      "default": "./dist/models/*.js"
    },
    "#services/*": {
      "types": "./src/services/*.ts",
      "default": "./dist/services/*.js"
    },
    "#utilities/*": {
      "types": "./src/utilities/*.ts",
      "default": "./dist/utilities/*.js"
    }
  },
  "snyk": true,
  "private": true,
  "packageManager": "yarn@4.4.1"
}
